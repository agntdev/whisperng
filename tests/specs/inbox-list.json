[
  {
    "name": "Inbox shows empty state",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "callback": "inbox:list", "messageId": 2 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": { "text": "📭 Your inbox is empty. Share your anonymous link to receive messages." }
          }
        ]
      }
    ]
  }
]
